# GitHub token used by local Flue runs for gh CLI/API operations.
# Required scopes for local testing against this repo: repo.
GITHUB_TOKEN=ghp_replace_me
GH_TOKEN=ghp_replace_me

# Repository slug used by the PR agent trust check when not running in GitHub Actions.
GITHUB_REPOSITORY=Citation-Media/moco-sdk

# Issue number used by the PR agent when not passing payload.issueNumber.
ISSUE_NUMBER=123

# Flue model provider credentials.
# The agents use the Workers AI model cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6.
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_API_TOKEN=replace_me
